.therapist-status {
    margin-bottom: 15px;
}

.status-badge {
    display: inline-block;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 13px;
    font-weight: 600;
}

.status-badge.accepting {
    background: #d1fae5;
    color: #065f46;
}

.status-badge.not-accepting {
    background: #fee2e2;
    color: #991b1b;
}

.therapist-actions {
    margin-top: auto;
    display: flex;
    gap: 10px;
    padding-top: 15px;
    border-top: 2px solid #f3f4f6;
}

.btn-therapist {
    flex: 1;
    padding: 12px 16px;
    border: none;
    border-radius: 10px;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
}

.btn-therapist.view {
    background: #f3f4f6;
    color: #374151;
}

.btn-therapist.view:hover {
    background: #e5e7eb;
}

.btn-therapist.book {
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    color: white;
}

.btn-therapist.book:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(99, 102, 241, 0.3);
}

.btn-therapist:disabled {
    background: #e5e7eb;
    color: #9ca3af;
    cursor: not-allowed;
    transform: none;
}

@media (max-width: 1024px) {
    .therapists-grid {
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    }
}

@media (max-width: 768px) {
    .therapists-controls {
        flex-direction: column;
    }
    
    .filter-group {
        flex-direction: column;
    }
    
    .therapists-grid {
        grid-template-columns: 1fr;
    }
    
    .quick-connect-therapists {
        grid-template-columns: 1fr;
    }
    
    .therapist-card {
        min-height: 380px;
    }
    
    .therapist-actions {
        flex-direction: column;
    }
}

.therapist-profile-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10000;
    padding: 20px;
    animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

.profile-modal-content {
    background: white;
    border-radius: 20px;
    max-width: 800px;
    width: 100%;
    max-height: 90vh;
    overflow-y: auto;
    position: relative;
    animation: slideUp 0.3s ease;
}

@keyframes slideUp {
    from { transform: translateY(50px); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
}

.profile-modal-header {
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    padding: 30px;
    color: white;
    border-radius: 20px 20px 0 0;
    position: relative;
}

.profile-close-btn {
    position: absolute;
    top: 20px;
    right: 20px;
    background: rgba(255, 255, 255, 0.2);
    border: none;
    color: white;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 20px;
    transition: all 0.3s ease;
}

.profile-close-btn:hover {
    background: rgba(255, 255, 255, 0.3);
    transform: rotate(90deg);
}

.profile-header-content {
    display: flex;
    align-items: center;
    gap: 20px;
}

.profile-avatar-large {
    width: 100px;
    height: 100px;
    border-radius: 50%;
    background: white;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 48px;
    flex-shrink: 0;
}

.profile-header-info h2 {
    margin: 0 0 10px 0;
    font-size: 28px;
}

.profile-header-info p {
    margin: 5px 0;
    opacity: 0.95;
    font-size: 16px;
}

.profile-modal-body {
    padding: 30px;
}

.profile-section {
    margin-bottom: 30px;
}

.profile-section h3 {
    color: #1f2937;
    font-size: 20px;
    margin-bottom: 15px;
    display: flex;
    align-items: center;
    gap: 10px;
}

.profile-section h3 i {
    color: #6366f1;
}

.profile-info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
}

.profile-info-item {
    background: #f9fafb;
    padding: 15px;
    border-radius: 10px;
    border-left: 4px solid #6366f1;
}

.profile-info-item label {
    font-size: 12px;
    color: #6b7280;
    text-transform: uppercase;
    font-weight: 600;
    display: block;
    margin-bottom: 5px;
}

.profile-info-item p {
    margin: 0;
    color: #1f2937;
    font-size: 16px;
    font-weight: 500;
}

.profile-bio {
    background: #f9fafb;
    padding: 20px;
    border-radius: 10px;
    line-height: 1.8;
    color: #4b5563;
}

.profile-specializations {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
}

.spec-badge {
    background: #e0e7ff;
    color: #4338ca;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 14px;
    font-weight: 500;
}

.profile-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 15px;
}

.stat-card {
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    padding: 20px;
    border-radius: 12px;
    text-align: center;
    color: white;
}

.stat-card h4 {
    margin: 0;
    font-size: 32px;
    font-weight: 700;
}

.stat-card p {
    margin: 5px 0 0 0;
    opacity: 0.9;
    font-size: 14px;
}

.profile-modal-footer {
    padding: 20px 30px;
    background: #f9fafb;
    border-radius: 0 0 20px 20px;
    display: flex;
    gap: 15px;
    justify-content: flex-end;
}

.btn-profile-action {
    padding: 12px 24px;
    border: none;
    border-radius: 10px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    gap: 8px;
}

.btn-book-now {
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    color: white;
}

.btn-book-now:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(99, 102, 241, 0.4);
}

.btn-close-modal {
    background: #e5e7eb;
    color: #374151;
}

.btn-close-modal:hover {
    background: #d1d5db;
}

.recommendation-alert {
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    color: white;
    padding: 20px;
    border-radius: 12px;
    margin-bottom: 30px;
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
    animation: slideDown 0.5s ease-out;
}

@keyframes slideDown {
    from {
        opacity: 0;
        transform: translateY(-20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.alert-content {
    display: flex;
    align-items: center;
    gap: 20px;
}

.alert-icon {
    font-size: 48px;
}

.alert-text {
    flex: 1;
}

.alert-text h3 {
    margin: 0 0 5px 0;
    font-size: 20px;
}

.alert-text p {
    margin: 0;
    opacity: 0.9;
}

.alert-actions {
    display: flex;
    gap: 10px;
}

.btn-sm {
    padding: 8px 16px;
    font-size: 14px;
}

.resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 24px;
    padding: 20px 0;
}

.resource-card {
    display: flex;
    flex-direction: column;
    height: auto;
    min-height: 300px;
}

.resource-description {
    flex-grow: 1;
}

.resource-footer {
    margin-top: auto;
}

/* ========== RECOMMENDATION BANNER & CARDS ========== */

.recommendation-banner {
    grid-column: 1 / -1;
    background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    padding: 24px;
    border-radius: 16px;
    margin-bottom: 24px;
    color: white;
    box-shadow: 0 4px 16px rgba(102, 126, 234, 0.3);
    min-height: 100px;
    display: block;
    visibility: visible;
}

.recommendation-banner h3 {
    margin: 0 0 10px 0;
    font-size: 24px;
    display: flex;
    align-items: center;
    gap: 10px;
}

.recommendation-banner p {
    margin: 0;
    opacity: 0.9;
    font-size: 16px;
}

.resource-card.recommended-card {
    position: relative;
    border: 3px solid #ffc107;
    background: linear-gradient(to bottom, #fffbf0 0%, white 50%);
}

.recommended-badge {
    position: absolute;
    top: -12px;
    right: 20px;
    background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);
    color: white;
    padding: 8px 16px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
    box-shadow: 0 2px 8px rgba(255, 193, 7, 0.4);
    z-index: 10;
}

.recommended-reason {
    background: #fff3cd;
    border-left: 4px solid #ffc107;
    padding: 12px;
    margin: 15px 0;
    border-radius: 8px;
    font-size: 13px;
    color: #856404;
}

.recommended-reason strong {
    color: #856404;
    display: block;
    margin-bottom: 4px;
}

.recommended-reason p {
    margin: 0;
    color: #856404;
    font-size: 13px;
    line-height: 1.4;
}

/* Ensure resources grid is visible */
.resources-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 24px;
    padding: 20px 0;
}

.resource-card {
    background: white;
    border-radius: 12px;
    padding: 24px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
    position: relative;
    border: 2px solid transparent;
}

.resource-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
}

.resource-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
    gap: 10px;
}

.resource-type-badge {
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
}

.type-article { background: #e3f2fd; color: #1976d2; }
.type-video { background: #ffebee; color: #c62828; }
.type-guide { background: #e8f5e8; color: #2e7d32; }
.type-worksheet { background: #fff3e0; color: #ef6c00; }

.resource-category {
    background: #f5f5f5;
    color: #666;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px;
}

.resource-card h3 {
    margin: 0 0 12px 0;
    color: #2c3e50;
    font-size: 18px;
    line-height: 1.4;
}

.resource-meta {
    display: flex;
    gap: 15px;
    margin: 15px 0;
    flex-wrap: wrap;
}

.resource-meta-item {
    display: flex;
    align-items: center;
    gap: 6px;
    color: #666;
    font-size: 13px;
}

.resource-description {
    color: #555;
    line-height: 1.5;
    margin: 15px 0;
    font-size: 14px;
}

.resource-footer {
    margin-top: 20px;
}

.btn-resource {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 20px;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s;
    border: none;
    cursor: pointer;
}

.btn-resource-primary {
    background: #667eea;
    color: white;
}

.btn-resource-primary:hover {
    background: #5a6fd8;
    transform: translateY(-2px);
}

