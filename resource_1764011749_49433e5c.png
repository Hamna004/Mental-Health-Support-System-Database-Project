}

.form-control {
    width: 100%;
    padding: 12px 15px;
    border: 2px solid #e9ecef;
    border-radius: 8px;
    font-size: 1rem;
    margin-bottom: 15px;
}

.form-control:focus {
    border-color: #4a6fa5;
    outline: none;
    box-shadow: 0 0 0 3px rgba(74, 111, 165, 0.1);
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

.therapist-card {
    animation: fadeInUp 0.5s ease-out;
}

@media (max-width: 768px) {
    .therapists-controls {
        flex-direction: column;
        align-items: stretch;
    }
    
    .search-box {
        min-width: auto;
    }
    
    .filter-group {
        justify-content: space-between;
    }
    
    .filter-select {
        flex: 1;
        min-width: auto;
    }
    
    .therapists-grid {
        grid-template-columns: 1fr;
    }
    
    .therapist-header {
        flex-direction: column;
        text-align: center;
        gap: 15px;
    }
    
    .therapist-avatar {
        width: 80px;
        height: 80px;
        font-size: 1.4rem;
    }
    
    .therapist-actions {
        flex-direction: column;
    }
    
    .therapist-actions .btn {
        min-width: auto;
    }
    
    .modal-content {
        margin: 20px;
    }
    
    .quick-connect-therapists {
        grid-template-columns: 1fr;
    }
}

.loading-therapists {
    display: flex;
    justify-content: center;
    align-items: center;
    height: 200px;
    color: #666;
}

.loading-therapists i {
    font-size: 2rem;
    margin-right: 10px;
}

.empty-therapists {
    text-align: center;
    padding: 60px 20px;
