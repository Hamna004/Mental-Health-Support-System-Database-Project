}

.languages-list {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}

.language-tag {
    background: #f8f9fa;
    color: #495057;
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 0.8rem;
