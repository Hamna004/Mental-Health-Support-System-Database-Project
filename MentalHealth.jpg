CREATE TABLE USERS(
    USER_ID INT PRIMARY KEY,
    USERNAME VARCHAR(50) UNIQUE NOT NULL,
    EMAIL VARCHAR(100) UNIQUE NOT NULL,
    PASSWORD_HASH VARCHAR(100) NOT NULL,
    FIRST_NAME VARCHAR(50) NOT NULL,
    LAST_NAME VARCHAR(50) NOT NULL,
    ROLE VARCHAR(20) NOT NULL CHECK(ROLE IN ('PATIENT', 'THERAPIST', 'ADMIN')),
    DOB DATE,
    PHONE_NUMBER VARCHAR(20),
    DATE_CREATED DATE NOT NULL,
    IS_ACTIVE CHAR(1) CHECK(IS_ACTIVE IN ('Y', 'N'))
);

CREATE TABLE THERAPIST_PROFILES(
    THERAPIST_ID INT PRIMARY KEY,
    SPECIALISATION VARCHAR(200) NOT NULL,
    QUALIFICATIONS VARCHAR(500),
    YEARS_OF_EXPERIENCE INT,
    BIO VARCHAR(2000),
    HOURLY_RATE NUMBER(8,2),
    IS_ACCEPTING_NEW_CLIENTS CHAR(1) CHECK(IS_ACCEPTING_NEW_CLIENTS IN ('Y','N')),
    CONSTRAINT FK_THERAPIST_USER FOREIGN KEY (THERAPIST_ID) REFERENCES USERS(USER_ID)
);

CREATE TABLE MOOD_LOGS (
    MOOD_LOG_ID NUMBER PRIMARY KEY,
    USER_ID NUMBER NOT NULL REFERENCES USERS(USER_ID),
    MOOD VARCHAR2(50) NOT NULL CONSTRAINT CHK_VALID_MOOD 
        CHECK (MOOD IN ('HAPPY', 'SAD', 'ANXIOUS', 'STRESSED', 'CALM', 'ANGRY', 'TIRED', 'EXCITED')),
    INTENSITY NUMBER(2) NOT NULL CHECK (INTENSITY BETWEEN 1 AND 10),
    LOG_DATE DATE DEFAULT SYSDATE NOT NULL,
    NOTES VARCHAR2(4000),
    CREATED_AT TIMESTAMP DEFAULT SYSTIMESTAMP NOT NULL
);

CREATE TABLE JOURNALS (
    JOURNAL_ID NUMBER PRIMARY KEY,
    USER_ID NUMBER NOT NULL REFERENCES USERS(USER_ID) ON DELETE CASCADE,
    TITLE VARCHAR2(200) NOT NULL,
    CONTENT CLOB NOT NULL,
    ENTRY_DATE DATE DEFAULT SYSDATE NOT NULL,
    IS_PRIVATE CHAR(1) DEFAULT 'Y' CHECK (IS_PRIVATE IN ('Y','N')),
    CREATED_AT TIMESTAMP DEFAULT SYSTIMESTAMP NOT NULL
);


CREATE TABLE SESSIONS (
    SESSION_ID NUMBER PRIMARY KEY,
    PATIENT_ID NUMBER NOT NULL REFERENCES USERS(USER_ID),
    THERAPIST_ID NUMBER NOT NULL REFERENCES USERS(USER_ID),
    SCHEDULED_DATE_TIME TIMESTAMP NOT NULL,
    DURATION_MINUTES NUMBER DEFAULT 60 CHECK (DURATION_MINUTES BETWEEN 30 AND 180),
    STATUS VARCHAR2(20) DEFAULT 'BOOKED' NOT NULL CHECK (STATUS IN ('BOOKED', 'COMPLETED', 'CANCELLED', 'NO-SHOW')),
    SESSION_NOTES CLOB,
    PATIENT_FEEDBACK CLOB,
    CREATED_AT TIMESTAMP DEFAULT SYSTIMESTAMP NOT NULL,
    CONSTRAINT CHK_PATIENT_THERAPIST_DIFF CHECK (PATIENT_ID <> THERAPIST_ID)
);

CREATE TABLE RESOURCES (
    RESOURCE_ID NUMBER PRIMARY KEY,
    THERAPIST_ID NUMBER NOT NULL REFERENCES USERS(USER_ID),
    TITLE VARCHAR2(255) NOT NULL,
    DESCRIPTION VARCHAR2(1000),
    RESOURCE_TYPE VARCHAR2(50) NOT NULL CHECK (RESOURCE_TYPE IN ('ARTICLE', 'VIDEO', 'GUIDE', 'WORKSHEET')),
    CATEGORY VARCHAR2(100) NOT NULL,
    FILE_URL VARCHAR2(500),
    EXTERNAL_LINK VARCHAR2(500),
    DATE_UPLOADED DATE DEFAULT SYSDATE NOT NULL,
    IS_APPROVED CHAR(1) DEFAULT 'N' CHECK (IS_APPROVED IN ('Y','N'))
);


CREATE TABLE RECOMMENDATIONS (
    RECOMMENDATION_ID NUMBER PRIMARY KEY,
    USER_ID NUMBER NOT NULL REFERENCES USERS(USER_ID),
    TYPE VARCHAR2(20) NOT NULL CHECK (TYPE IN ('SESSION', 'RESOURCE')),
    RELATED_ID NUMBER NOT NULL,
    REASON VARCHAR2(1000) NOT NULL,
    IS_READ CHAR(1) DEFAULT 'N' CHECK (IS_READ IN ('Y','N')),
    CREATED_AT DATE DEFAULT SYSDATE NOT NULL
);

CREATE TABLE SPECIALIZATIONS (
    SPECIALIZATION_ID NUMBER PRIMARY KEY,
    SPECIALIZATION_NAME VARCHAR2(100) UNIQUE NOT NULL
);

CREATE TABLE THERAPIST_SPECIALIZATIONS (
    THERAPIST_ID NUMBER NOT NULL REFERENCES USERS(USER_ID),
    SPECIALIZATION_ID NUMBER NOT NULL REFERENCES SPECIALIZATIONS(SPECIALIZATION_ID),
    PRIMARY KEY (THERAPIST_ID, SPECIALIZATION_ID)
);


CREATE TABLE ADMIN_LOGS (
    LOG_ID NUMBER PRIMARY KEY,
    ADMIN_ID NUMBER NOT NULL REFERENCES USERS(USER_ID),
    ACTION VARCHAR2(200) NOT NULL,
    IP_ADDRESS VARCHAR2(45),
    LOG_TIMESTAMP TIMESTAMP DEFAULT SYSTIMESTAMP NOT NULL
);

